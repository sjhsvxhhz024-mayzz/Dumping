# =========================================================================
#  Eclips Oxide — .gitignore
# =========================================================================
#  Big/generated artifacts kept out of the tree. Regenerate locally from
#  the game binaries you already have on disk.
# =========================================================================

# ---- Target game binaries (dumper input) ---------------------------------
Nov/libil2cpp.so
Nov/global-metadata.dat

# ---- Dumper outputs (regenerated by dumpgen.py / scriptgen.py / il2cppgen.py)
Nov/dump.cs
Nov/script.json
Nov/il2cpp.h
Nov/codereg.json

# ---- Menu-side generated / build artifacts --------------------------------
proj/dump.cs
proj/libs/arm64-v8a/oxideesp
proj/libs/armeabi-v7a/*
proj/libs/x86/*
proj/libs/x86_64/*
!proj/libs/**/.gitkeep

# ---- NDK / native build products -----------------------------------------
obj/
libs/*/lib*.so
libs/*/lib*.a
*.o
*.a
*.so
*.d

# ---- Python bytecode -----------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# ---- OS / editor junk ----------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ---- Local env / secrets -------------------------------------------------
.env
.env.local
*.pem
*.key
