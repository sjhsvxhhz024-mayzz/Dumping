# =========================================================================
#  Eclips Oxide — .gitignore
# =========================================================================
#  Big/generated artifacts kept out of the tree. Regenerate locally from
#  the game binaries you already have on disk.
# =========================================================================

# ---- Menu-side generated / build artifacts --------------------------------
proj/dump.cs
# NDK build products (all ABIs, any executable / library name).
proj/libs/arm64-v8a/*
proj/libs/armeabi-v7a/*
proj/libs/x86/*
proj/libs/x86_64/*
!proj/libs/**/.gitkeep
proj/obj/

# ---- Vendored font blob (6.7 MB C-array, bring your own or regenerate) ---
proj/include/ImGui/font/Font.h

# ---- NDK / native build products -----------------------------------------
obj/
libs/*/lib*.so
libs/*/lib*.a
*.o
*.a
*.so
*.d

# ---- Python bytecode -----------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd

# ---- OS / editor junk ----------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ---- Local env / secrets -------------------------------------------------
.env
.env.local
*.pem
*.key
